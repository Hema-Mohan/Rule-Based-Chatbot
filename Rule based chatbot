# Simple Rule-Based Chatbot
# Python Developer Internship - Task 8

def chatbot():
    print("🤖 Hello! I am your simple chatbot.")
    print("Type 'exit' to end the conversation.\n")

    while True:
        user_input = input("You: ").lower()

        if user_input == "hello" or user_input == "hi":
            print("Bot: Hi there! How can I help you?")

        elif user_input == "how are you":
            print("Bot: I'm just a program, but I'm doing great! 😊")

        elif user_input == "what is your name":
            print("Bot: I am a Rule-Based Chatbot.")

        elif user_input == "help":
            print("Bot: You can greet me, ask my name, or ask how I am.")

        elif user_input == "exit":
            print("Bot: Goodbye! Have a nice day! 👋")
            break

        else:
            print("Bot: Sorry, I don't understand that.")

if __name__ == "__main__":
    chatbot()
